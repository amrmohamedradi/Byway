# Backend API Configuration
# This must be set to your deployed backend API URL
# For local development: http://localhost:5000 or your local backend URL
# For production deployments (Vercel, etc.): https://your-backend-domain.com
# Important: This variable MUST be configured in your deployment platform's environment settings
VITE_API_BASE_URL=https://bywayapi.runasp.net
VITE_API_URL=https://bywayapi.runasp.net

# ─── Social OAuth (public credentials — safe to commit) ──────────────────────
# These are OAuth *client* identifiers, not secrets. They must still be configured
# in your deployment platform (Vercel > Settings > Environment Variables).

# Google Identity Services — obtain from Google Cloud Console >
#   APIs & Services > Credentials > OAuth 2.0 Client IDs
# Add https://byway-lime.vercel.app to "Authorized JavaScript origins".
VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Facebook JavaScript SDK — obtain from developers.facebook.com > Your App > Settings > Basic
# Add https://byway-lime.vercel.app to "App Domains" and configure Facebook Login product.
VITE_FACEBOOK_APP_ID=your-facebook-app-id

